# Copy to .env and fill in. All VITE_* vars are build-time — exposed in the
# bundle. Only put values here you're okay with a visitor seeing.
#
# Cloudflare Worker secrets (MAPILLARY_TOKEN, GOOGLE_MAPS_API_KEY) are
# set via `wrangler secret put` and are NOT in .env.

# Sentry browser DSN for client-side error reporting. Optional — app runs
# without it. https://sentry.io/
VITE_SENTRY_DSN=

# Mapillary API token is a Worker secret named MAPILLARY_TOKEN — NOT a
# VITE_ build-time var. Mapillary tokens cannot be referrer-locked, so
# shipping one in the client bundle would let anyone copy it. Set via:
#   wrangler secret put MAPILLARY_TOKEN
#
# Google Maps API key is a Worker secret named GOOGLE_MAPS_API_KEY —
# used for (a) Street View Static images in single-image popovers and
# (b) the one-off scripts/fetch-google-routes.ts Directions run. Kept
# server-side so the key never ships in the client bundle. Restrict
# the key in Google Cloud Console → Credentials to:
#   - APIs: Directions API + Street View Static API only
# Set via:
#   wrangler secret put GOOGLE_MAPS_API_KEY

# Plausible analytics is loaded as a static <script> in index.html
# (no env keys required) and gated to the prod hostname there. The
# domain it reports under is hardcoded; configure the property on
# https://plausible.io/sites. PostHog was removed 2026-05-05 — see
# docs/product/decisions.md.

# Userback feedback widget access token from https://app.userback.io/
# (Settings → Integrations → Widget access token). Only loaded on
# bike-map.fryanpan.com. Leave blank to disable the widget.
VITE_USERBACK_TOKEN=

# MapTiler API key — used by the "Leaflet + MapTiler Streets v2 light"
# rendering engine (selectable from Admin Tools → Settings). Leave blank
# to fall back to OSM Carto when MapTiler is selected. Get a free key
# at https://cloud.maptiler.com/account/keys/. Bundle into the client
# is intentional — restrict the key in MapTiler dashboard by HTTP
# referrer to bike-map.fryanpan.com.
VITE_MAPTILER_KEY=

# Google Maps JavaScript API key — single client-side key powering BOTH:
#   - The "Google Maps" rendering engine (Admin Settings → Map engine)
#   - The Google geocoder adapter (Admin Settings → Geocoder = Google):
#     Places Autocomplete + Place Details + (reverse) Geocoding.
# Distinct from the server-side GOOGLE_MAPS_API_KEY Worker secret because
# referrer-locked client keys are safe to bundle. Restrict in Google
# Cloud Console → Credentials to:
#   - APIs: Maps JavaScript API + Places API + Geocoding API
#   - HTTP referrers: bike-map.fryanpan.com (+ localhost for dev)
# Leave blank to use the Nominatim geocoder + OSM Carto map defaults.
VITE_GOOGLE_MAPS_KEY=
